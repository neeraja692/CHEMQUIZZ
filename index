  {q:'What defines an Acid?',a:'Donates H⁺ ions in solution. pH < 7. Turns blue litmus red. Reacts with metals, bases and carbonates.'},
  {q:'What is the pH of a neutral solution?',a:'pH 7 at 25°C — equal concentrations of H⁺ and OH⁻. Pure water is the classic example.'},
  {q:'What does a strong acid do in water?',a:'Fully dissociates — every molecule releases its H⁺. Examples: HCl, H₂SO₄, HNO₃.'},
  {q:'What is a buffer solution?',a:'Resists pH changes when small amounts of acid or base are added. Essential in biological systems.'},
  {q:'What colour does litmus turn in an alkali?',a:'Blue. Alkalis have excess OH⁻ ions and pH > 7.'},
  {q:'Products of acid + metal carbonate?',a:'Salt + water + carbon dioxide gas. E.g. HCl + CaCO₃ → CaCl₂ + H₂O + CO₂↑'},
  {q:'Define neutralisation.',a:'Acid + base → salt + water. pH moves toward 7. The reaction is exothermic.'},
  {q:'Formula for sulfuric acid?',a:'H₂SO₄ — 2 H, 1 S, 4 O. A strong diprotic acid releasing 2 H⁺ ions per molecule.'},
];
const BALS=[
  {label:'Hydrogen + Oxygen → Water',parts:[{m:'H₂'},{m:'O₂'}],prods:[{m:'H₂O'}],ans:[2,1,2],hint:'2 H₂ gives 4 H atoms → 2 H₂O. 1 O₂ gives 2 O = 2 H₂O. ✓'},
  {label:'Sodium + Chlorine → Sodium Chloride',parts:[{m:'Na'},{m:'Cl₂'}],prods:[{m:'NaCl'}],ans:[2,1,2],hint:'Cl₂ = 2 Cl atoms → 2 NaCl needed → 2 Na needed.'},
  {label:'Methane + Oxygen → CO₂ + Water',parts:[{m:'CH₄'},{m:'O₂'}],prods:[{m:'CO₂'},{m:'H₂O'}],ans:[1,2,1,2],hint:'1 CH₄ → 1 CO₂ + 2 H₂O. Oxygen needed: 2 + 2 = 4 → 2 O₂.'},
];
const LB=[{n:'Arjun S.',pts:1420},{n:'Priya M.',pts:1380},{n:'Kenji T.',pts:1260},{n:'You',pts:0,you:true},{n:'Fatima A.',pts:880},{n:'Lucas B.',pts:740}];

// ═══ STATE ═══
let score=0,xp=0,level=1,cKey='periodic',cIdx=0,cCorrect=0,answered=false,fcIdx=0,fcFlip=false,balIdx=0;

// ═══ BACKGROUND RAYS ═══
(function(){
  const w=document.getElementById('raysEl');
  [{a:15,w:130,h:130,d:0,t:5},{a:25,w:75,h:140,d:.7,t:6},{a:36,w:210,h:150,d:.3,t:7},
   {a:46,w:55,h:130,d:1.2,t:5.5},{a:56,w:150,h:160,d:.5,t:8},{a:66,w:42,h:130,d:1.8,t:6},
   {a:76,w:110,h:140,d:.9,t:7},{a:88,w:185,h:120,d:.2,t:5},{a:102,w:62,h:130,d:1.5,t:6.5},{a:118,w:88,h:110,d:.6,t:7}]
  .forEach(r=>{
    const d=document.createElement('div');d.className='r';
    d.style.cssText=`transform:rotate(${r.a}deg);animation-delay:${r.d}s;animation-duration:${r.t}s;`;
    const s=document.createElement('span');
    s.style.cssText=`width:${r.w}px;height:${r.h*9}px;animation-delay:${r.d}s;animation-duration:${r.t}s;`;
    d.appendChild(s);w.appendChild(d);
  });
  // sparkles
  const bw=document.getElementById('bgWrap');
  for(let i=0;i<22;i++){
    const s=document.createElement('div');s.className='sparkle';
    const sz=Math.random()*6+2;
    s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*95}%;top:${Math.random()*85}%;animation-duration:${Math.random()*2+1.5}s;animation-delay:${Math.random()*4}s;`;
    bw.appendChild(s);
    // bubbles
    const b=document.createElement('div');b.className='bub';
    const bs=Math.random()*22+8;
    b.style.cssText=`width:${bs}px;height:${bs}px;left:${Math.random()*92}%;bottom:${Math.random()*30}%;animation-duration:${Math.random()*12+8}s;animation-delay:${Math.random()*8}s;`;
    bw.appendChild(b);
  }
})();

// ═══ HUD ═══
function updateHUD(){
  ['hudScore','qHudScore','balScore','fcScore'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=score;});
  ['hudLv','qHudLv'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=level;});
  const xel=document.getElementById('hudXP');if(xel)xel.textContent=xp;
  const xf=document.getElementById('xpFill');if(xf)xf.style.width=Math.min(xp%100,100)+'%';
}
function award(pts,label){
  xp+=pts;score+=pts;
  if(xp>=level*100)level++;
  updateHUD();
  // popup
  const pop=document.createElement('div');
  pop.className='score-pop';pop.textContent=(label||'+')+pts+' XP!';
  document.body.appendChild(pop);
  setTimeout(()=>pop.remove(),2100);
}

// ═══ NAV ═══
function show(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');window.scrollTo(0,0);}
function showHome(){show('landingScreen');}
function startGameHub(){updateHUD();show('hubScreen');}
function goHub(){updateHUD();show('hubScreen');}

// ═══ QUIZ ═══
function startQuiz(k){
  cKey=k;cIdx=0;cCorrect=0;answered=false;
  document.getElementById('qHudTitle').textContent=QD[k].title;
  const r=document.getElementById('streakDots');r.innerHTML='';
  QD[k].questions.forEach((_,i)=>{const d=document.createElement('div');d.className='sd';d.id='sd'+i;r.appendChild(d);});
  renderQ();show('quizScreen');
}
function renderQ(){
  const d=QD[cKey],t=d.questions.length,q=d.questions[cIdx];
  document.getElementById('qNum').textContent='Question '+String(cIdx+1).padStart(2,'0');
  document.getElementById('qText').textContent=q.q;
  const v=document.getElementById('qVis');
  if(q.vis){v.textContent='🔬 '+q.vis;v.style.display='block';}else{v.style.display='none';}
  const pct=Math.round((cIdx/t)*100);
  document.getElementById('progLbl').textContent=`Question ${cIdx+1} of ${t}`;
  document.getElementById('progPct').textContent=pct+'%';
  document.getElementById('progFill').style.width=pct+'%';
  const g=document.getElementById('optsGrid');g.innerHTML='';
  ['A','B','C','D'].forEach((l,i)=>{
    const b=document.createElement('button');b.className='opt-btn';b.setAttribute('data-l',l);b.textContent=q.opts[i];
    b.onclick=()=>pick(i);g.appendChild(b);
  });
  document.getElementById('fbBox').className='fb-box';
  document.getElementById('fbBox').textContent='';
  document.getElementById('nextBtn').classList.remove('show');
  answered=false;
}
function pick(idx){
  if(answered)return;answered=true;
  const q=QD[cKey].questions[cIdx],ok=q.ans===idx;
  document.querySelectorAll('.opt-btn').forEach(b=>b.disabled=true);
  document.querySelectorAll('.opt-btn')[idx].classList.add(ok?'correct':'wrong');
  if(!ok)document.querySelectorAll('.opt-btn')[q.ans].classList.add('correct');
  const fb=document.getElementById('fbBox');
  fb.className='fb-box show '+(ok?'fb-ok':'fb-bad');
  fb.innerHTML=(ok?'✅ Correct! ':'❌ Not quite. ')+q.hint;
  if(ok){cCorrect++;award(20,'Correct! +');document.getElementById('sd'+cIdx).classList.add('lit');}
  document.getElementById('nextBtn').classList.add('show');
}
function nextQ(){cIdx++;if(cIdx>=QD[cKey].questions.length)showResults();else renderQ();}
function showResults(){
  const t=QD[cKey].questions.length,pct=Math.round((cCorrect/t)*100);
  document.getElementById('rScore').textContent=cCorrect+'/'+t;
  let emoji,msg,badges;
  if(pct===100){emoji='🌟';msg='Perfect score! You are a true Chemistry Master!';badges=['Perfect 100%','Gold Star','Flawless'];}
  else if(pct>=80){emoji='🎉';msg='Excellent work! You have a strong grasp of this topic.';badges=['High Scorer','Sharp Mind'];}
  else if(pct>=60){emoji='👍';msg='Good effort! A little more practice will get you to the top.';badges=['Progressing','Keep it up!'];}
  else{emoji='💡';msg='Every attempt makes you stronger — keep going!';badges=['Brave Learner'];}
  document.getElementById('rEmoji').textContent=emoji;
  document.getElementById('rMsg').textContent=msg;
  document.getElementById('rBadges').innerHTML=badges.map(b=>`<div class="r-badge">🏅 ${b}</div>`).join('');
  LB.find(r=>r.you).pts=score;
  show('resultsScreen');
}
function retryQuiz(){startQuiz(cKey);}

// ═══ BALANCER ═══
function startBalancer(){balIdx=0;renderBal();show('balancerScreen');}
function renderBal(){
  const eq=BALS[balIdx];
  let h=`<p style="text-align:center;font-family:'Fredoka One',sans-serif;font-size:1rem;color:rgba(255,255,255,0.9);margin-bottom:10px;">${eq.label}</p>`;
  h+=`<div class="eq-display">`;
  eq.parts.forEach((p,i)=>{if(i)h+=`<span class="eq-plus">+</span>`;h+=`<input class="coeff" type="number" min="1" max="9" id="ci${i}" placeholder="?"><span class="eq-mol">${p.m}</span>`;});
  h+=`<span class="eq-arrow">→</span>`;
  eq.prods.forEach((p,i)=>{if(i)h+=`<span class="eq-plus">+</span>`;const ix=eq.parts.length+i;h+=`<input class="coeff" type="number" min="1" max="9" id="ci${ix}" placeholder="?"><span class="eq-mol">${p.m}</span>`;});
  h+=`</div><div class="bal-hint">💡 ${eq.hint}</div>`;
  document.getElementById('balContent').innerHTML=h;
  document.getElementById('balFb').className='fb-box';document.getElementById('balFb').textContent='';
}
function checkBal(){
  const eq=BALS[balIdx];let ok=true;
  eq.ans.forEach((a,i)=>{const inp=document.getElementById('ci'+i),v=parseInt(inp.value);
    if(v===a){inp.classList.add('cok');inp.classList.remove('cbad');}else{inp.classList.add('cbad');inp.classList.remove('cok');ok=false;}});
  const fb=document.getElementById('balFb');
  if(ok){fb.className='fb-box show fb-ok';fb.textContent='✅ Perfectly balanced! The equation is correct.';award(30,'Balance +');}
  else{fb.className='fb-box show fb-bad';fb.textContent='❌ Not balanced yet — check the highlighted inputs.';}
  document.getElementById('balScore').textContent=score;
}
function nextBal(){balIdx=(balIdx+1)%BALS.length;renderBal();}

// ═══ FLASHCARDS ═══
function startFlashcards(){fcIdx=0;fcFlip=false;renderFC();show('flashcardScreen');}
function renderFC(){
  document.getElementById('fcQ').textContent=FC[fcIdx].q;
  document.getElementById('fcA').textContent=FC[fcIdx].a;
  document.getElementById('fcCnt').textContent=`Card ${fcIdx+1} of ${FC.length}`;
  fcFlip=false;document.getElementById('fcInner').classList.remove('flip');
}
function flipCard(){fcFlip=!fcFlip;document.getElementById('fcInner').classList.toggle('flip',fcFlip);if(fcFlip)award(5,'Flip +');}
function nextCard(){fcIdx=(fcIdx+1)%FC.length;renderFC();}
function prevCard(){fcIdx=(fcIdx-1+FC.length)%FC.length;renderFC();}

// ═══ LEADERBOARD ═══
function showLeaderboard(){
  LB.find(r=>r.you).pts=score;
  const sorted=[...LB].sort((a,b)=>b.pts-a.pts);
  document.getElementById('lbList').innerHTML=sorted.map((r,i)=>`
    <div class="lb-row ${r.you?'you':''}">
      <div class="lb-rank">${['🥇','🥈','🥉'][i]||'#'+(i+1)}</div>
      <div class="lb-name">${r.you?'<strong>⭐ You</strong>':r.n}</div>
      <div class="lb-pts">${r.pts.toLocaleString()} pts</div>
    </div>`).join('');
  show('leaderboardScreen');
}

updateHUD();
</script>
</body>
