<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ChemQuest — Learn Chemistry Through Gaming</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fredoka+One&display=swap" rel="stylesheet">
<style>
:root{
  --sky1:#1a8fe3;--sky2:#0d6ec4;--sky3:#0a4f9e;
  --light:#e8f6ff;--pale:#c5e8ff;--white:#ffffff;
  --orange:#ff7b1c;--orange2:#ff9b3d;--orange-glow:rgba(255,123,28,0.35);
  --gold:#f9d71c;--teal:#1ecfb0;--green:#2ed573;
  --red:#ff5252;--card-bg:rgba(255,255,255,0.18);
  --card-border:rgba(255,255,255,0.5);
  --shadow:0 8px 32px rgba(0,60,140,0.25);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{
  font-family:'Nunito',sans-serif;
  background:linear-gradient(180deg,#0d6ec4 0%,#1a8fe3 30%,#3aabe8 60%,#5bc0f0 100%);
  min-height:100vh;overflow-x:hidden;color:#fff;
  position:relative;
}

/* ═══════════════════ BG EFFECTS ═══════════════════ */
.bg-wrap{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;}

/* Sun rays from top-left */
.sun{position:absolute;top:-180px;left:-180px;width:700px;height:700px;
  background:radial-gradient(circle at 40% 40%,
    rgba(255,255,200,0.9) 0%,rgba(255,220,80,0.55) 18%,
    rgba(255,180,30,0.22) 38%,transparent 58%);
  animation:sunP 7s ease-in-out infinite;}
@keyframes sunP{0%,100%{opacity:.85;transform:scale(1)}50%{opacity:1;transform:scale(1.06)}}

.rays{position:absolute;top:0;left:0;width:100%;height:100%;}
.r{position:absolute;top:0;left:0;transform-origin:0 0;animation:rF 6s ease-in-out infinite;}
.r span{display:block;border-radius:0 999px 999px 0;
  background:linear-gradient(90deg,rgba(255,255,200,0.28) 0%,transparent 100%);
  animation:rS 6s ease-in-out infinite;}
@keyframes rF{0%,100%{opacity:.15}50%{opacity:.55}}
@keyframes rS{0%,100%{opacity:.5}50%{opacity:1}}

/* Sparkles */
.sparkle{position:absolute;border-radius:50%;background:rgba(255,255,255,0.7);
  animation:sparkleA ease-in-out infinite;}
@keyframes sparkleA{0%,100%{transform:scale(0);opacity:0}50%{transform:scale(1);opacity:1}}

/* Bubbles floating up */
.bub{position:absolute;border-radius:50%;
  border:2px solid rgba(255,255,255,0.6);
  background:radial-gradient(circle at 35% 35%,rgba(255,255,255,0.5),rgba(100,200,255,0.1));
  animation:bubUp linear infinite;}
@keyframes bubUp{0%{transform:translateY(0) scale(1);opacity:.7}
  60%{opacity:.6}100%{transform:translateY(-110vh) scale(0.6);opacity:0}}

/* Floor glow */
.floor-glow{position:absolute;bottom:0;left:0;right:0;height:200px;
  background:linear-gradient(0deg,rgba(30,207,176,0.18) 0%,transparent 100%);}

/* Lab table reflection */
.lab-table{position:absolute;bottom:0;left:0;right:0;height:120px;
  background:linear-gradient(180deg,transparent,rgba(0,40,100,0.3));
  border-top:1px solid rgba(255,255,255,0.1);}

/* ═══════════════════ NAVBAR ═══════════════════ */
nav{
  position:relative;z-index:10;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;height:68px;
  background:rgba(10,60,140,0.35);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,0.18);
}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-logo .flask{font-size:1.6rem;}
.nav-logo span{font-family:'Fredoka One',sans-serif;font-size:1.4rem;color:#fff;letter-spacing:.04em;}
.nav-links{display:flex;gap:30px;list-style:none;}
.nav-links a{color:rgba(255,255,255,0.88);text-decoration:none;font-weight:600;font-size:.9rem;
  transition:color .2s;}
.nav-links a:hover{color:#fff;}
.nav-cta{background:linear-gradient(135deg,var(--orange),var(--orange2));
  border:none;padding:10px 26px;border-radius:30px;cursor:pointer;
  color:#fff;font-family:'Nunito',sans-serif;font-size:.9rem;font-weight:800;
  box-shadow:0 4px 18px var(--orange-glow);transition:all .22s;letter-spacing:.02em;}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 28px var(--orange-glow);}

/* ═══════════════════ SCREENS ═══════════════════ */
.screen{display:none;position:relative;z-index:2;}
.screen.active{display:block;animation:fadeUp .4s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ═══════════════════ HERO / LANDING ═══════════════════ */
.hero{
  display:grid;grid-template-columns:1fr auto;
  align-items:center;gap:20px;
  padding:60px 60px 0;min-height:420px;
  position:relative;
}
.hero-text{max-width:520px;}
.hero-tag{
  display:inline-block;
  background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.4);
  border-radius:30px;padding:5px 16px;font-size:.78rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;margin-bottom:18px;
  backdrop-filter:blur(6px);
}
.hero h1{
  font-family:'Fredoka One',sans-serif;
  font-size:clamp(2.2rem,5.5vw,3.6rem);
  line-height:1.1;color:#fff;margin-bottom:16px;
  text-shadow:0 4px 20px rgba(0,40,120,0.4);
}
.hero h1 .gold{color:var(--gold);}
.hero-sub{font-size:1.05rem;color:rgba(255,255,255,0.88);margin-bottom:32px;font-weight:400;line-height:1.6;}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;}
.btn-primary{
  background:linear-gradient(135deg,var(--orange),var(--orange2));
  border:none;padding:14px 34px;border-radius:40px;cursor:pointer;
  color:#fff;font-family:'Nunito',sans-serif;font-size:1rem;font-weight:800;
  box-shadow:0 6px 24px var(--orange-glow);transition:all .22s;letter-spacing:.02em;
}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 10px 32px var(--orange-glow);}
.btn-ghost{
  background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.6);
  padding:12px 30px;border-radius:40px;cursor:pointer;
  color:#fff;font-family:'Nunito',sans-serif;font-size:1rem;font-weight:700;
  backdrop-filter:blur(6px);transition:all .22s;
}
.btn-ghost:hover{background:rgba(255,255,255,0.32);transform:translateY(-2px);}

/* Beaker hero image */
.hero-beaker{position:relative;width:260px;flex-shrink:0;align-self:flex-end;}
.hero-beaker svg{width:100%;filter:drop-shadow(0 0 30px rgba(30,207,176,0.6)) drop-shadow(0 0 60px rgba(80,200,255,0.4));}
.beaker-liq{animation:beakerRock 4s ease-in-out infinite;}
@keyframes beakerRock{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.beaker-bub{animation:bkBub linear infinite;}
@keyframes bkBub{0%{transform:translateY(0);opacity:.8}100%{transform:translateY(-80px);opacity:0}}

/* Feature strip */
.feature-strip{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  margin:44px 40px 0;border-radius:18px;overflow:hidden;
  box-shadow:var(--shadow);
}
.feat{
  background:rgba(10,55,120,0.55);
  backdrop-filter:blur(14px);
  border:1px solid rgba(255,255,255,0.18);
  padding:24px 20px;text-align:center;
  transition:background .22s;cursor:pointer;
  position:relative;overflow:hidden;
}
.feat:not(:last-child){border-right:1px solid rgba(255,255,255,0.15);}
.feat:hover{background:rgba(20,80,180,0.65);}
.feat-icon{font-size:2rem;margin-bottom:10px;display:block;}
.feat-title{font-family:'Fredoka One',sans-serif;font-size:1rem;color:var(--pale);margin-bottom:6px;}
.feat-desc{font-size:.75rem;color:rgba(255,255,255,0.7);line-height:1.5;}
.feat-badge{
  position:absolute;top:10px;right:10px;
  background:var(--orange);color:#fff;font-size:.6rem;font-weight:800;
  padding:2px 8px;border-radius:20px;text-transform:uppercase;letter-spacing:.05em;
}

/* Why section */
.why-section{padding:50px 60px 30px;text-align:center;}
.section-title{font-family:'Fredoka One',sans-serif;font-size:2rem;color:#fff;margin-bottom:8px;
  text-shadow:0 3px 14px rgba(0,40,120,0.4);}
.section-title .accent{color:var(--gold);}
.why-dot{width:8px;height:8px;border-radius:50%;background:var(--teal);margin:0 auto 32px;}
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:24px;}
.why-card{
  background:rgba(255,255,255,0.14);
  border:1px solid rgba(255,255,255,0.32);
  border-radius:20px;padding:30px 22px;text-align:center;
  backdrop-filter:blur(10px);
  transition:transform .25s,box-shadow .25s;
  box-shadow:0 4px 20px rgba(0,40,120,0.2);
}
.why-card:hover{transform:translateY(-6px);box-shadow:0 14px 36px rgba(0,40,120,0.35);}
.why-orb{
  width:88px;height:88px;border-radius:50%;margin:0 auto 18px;
  display:flex;align-items:center;justify-content:center;font-size:2.4rem;
  box-shadow:0 6px 24px rgba(0,40,120,0.3);
}
.orb-orange{background:radial-gradient(135deg,#ff9b3d,#ff6b00);}
.orb-blue  {background:radial-gradient(135deg,#5bc4f0,#1a7ccc);}
.orb-teal  {background:radial-gradient(135deg,#1ecfb0,#0a9a84);}
.why-card h3{font-family:'Fredoka One',sans-serif;font-size:1.15rem;color:#fff;margin-bottom:8px;}
.why-card p{font-size:.82rem;color:rgba(255,255,255,0.8);line-height:1.6;}

/* CTA banner */
.cta-banner{margin:40px 60px;text-align:center;padding:44px;
  background:linear-gradient(135deg,rgba(255,255,255,0.15),rgba(255,255,255,0.07));
  border:1px solid rgba(255,255,255,0.3);border-radius:24px;
  backdrop-filter:blur(12px);}
.cta-banner h2{font-family:'Fredoka One',sans-serif;font-size:2rem;color:#fff;margin-bottom:20px;}

/* Footer */
footer{text-align:center;padding:24px;color:rgba(255,255,255,0.5);font-size:.78rem;
  border-top:1px solid rgba(255,255,255,0.1);}
footer a{color:rgba(255,255,255,0.6);text-decoration:none;margin:0 10px;}

/* ═══════════════════ GAME HUD ═══════════════════ */
.game-hud{
  position:relative;z-index:5;
  display:flex;align-items:center;gap:12px;padding:12px 40px;
  background:rgba(10,55,120,0.5);backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,0.15);
}
.hud-pill{
  display:flex;align-items:center;gap:8px;
  background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);
  border-radius:30px;padding:6px 16px;font-size:.82rem;font-weight:700;
}
.hud-pill span.val{color:var(--gold);font-size:.95rem;}
.hud-xp-wrap{flex:1;height:8px;background:rgba(0,0,0,0.2);border-radius:4px;overflow:hidden;max-width:200px;}
.hud-xp-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--green));border-radius:4px;transition:width .5s ease;}
.hud-back{
  background:rgba(255,255,255,0.15);border:1.5px solid rgba(255,255,255,0.4);
  border-radius:30px;padding:7px 18px;cursor:pointer;
  color:#fff;font-family:'Nunito',sans-serif;font-size:.82rem;font-weight:700;transition:all .2s;
}
.hud-back:hover{background:rgba(255,255,255,0.25);}

/* ═══════════════════ MODULE PICKER ═══════════════════ */
.mod-screen{padding:40px;}
.mod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;margin-top:24px;}
.mod-card{
  background:linear-gradient(145deg,rgba(255,255,255,0.2),rgba(255,255,255,0.08));
  border:1.5px solid rgba(255,255,255,0.4);border-radius:20px;
  padding:26px 22px;cursor:pointer;
  transition:all .28s cubic-bezier(.22,.68,0,1.2);
  box-shadow:0 4px 20px rgba(0,40,120,0.2);
  position:relative;overflow:hidden;
  backdrop-filter:blur(10px);
}
.mod-card::after{content:'';position:absolute;inset:0;border-radius:20px;
  background:linear-gradient(135deg,rgba(255,255,255,0.1),transparent);
  opacity:0;transition:opacity .25s;}
.mod-card:hover{transform:translateY(-6px) scale(1.02);border-color:rgba(255,255,255,0.7);
  box-shadow:0 16px 40px rgba(0,40,120,0.4);}
.mod-card:hover::after{opacity:1;}
.mc-icon{font-size:2.4rem;margin-bottom:12px;display:block;}
.mc-title{font-family:'Fredoka One',sans-serif;font-size:1.1rem;color:#fff;margin-bottom:6px;}
.mc-desc{font-size:.78rem;color:rgba(255,255,255,0.75);line-height:1.5;}
.mc-badge{position:absolute;top:12px;right:12px;background:var(--orange);color:#fff;
  font-size:.6rem;font-weight:800;padding:3px 9px;border-radius:20px;text-transform:uppercase;}

/* ═══════════════════ QUIZ ═══════════════════ */
.quiz-wrap{padding:32px 40px;}
.quiz-prog{margin-bottom:22px;}
.prog-row{display:flex;justify-content:space-between;font-size:.78rem;font-weight:700;
  color:rgba(255,255,255,0.8);margin-bottom:6px;}
.prog-track{height:8px;background:rgba(0,0,0,0.2);border-radius:4px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--orange),var(--gold));
  border-radius:4px;transition:width .5s ease;}
.streak-dots{display:flex;gap:8px;justify-content:center;margin-bottom:22px;}
.sd{width:12px;height:12px;border-radius:50%;background:rgba(255,255,255,0.2);
  border:2px solid rgba(255,255,255,0.35);transition:all .3s;}
.sd.lit{background:var(--gold);border-color:var(--orange);box-shadow:0 0 10px rgba(249,215,28,0.6);}
.q-card{
  background:rgba(10,55,120,0.5);backdrop-filter:blur(14px);
  border:1.5px solid rgba(255,255,255,0.25);border-radius:22px;
  padding:32px;margin-bottom:18px;
  box-shadow:0 8px 32px rgba(0,20,80,0.3),inset 0 1px 0 rgba(255,255,255,0.12);
}
.q-num{font-size:.72rem;font-weight:800;color:var(--teal);letter-spacing:.18em;text-transform:uppercase;margin-bottom:12px;}
.q-text{font-size:1.12rem;line-height:1.7;color:#fff;font-weight:600;}
.q-vis{margin-top:14px;padding:10px 16px;background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.2);border-radius:12px;
  font-size:.8rem;color:var(--pale);font-weight:600;}
.opts-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:500px){.opts-grid{grid-template-columns:1fr;}}
.opt-btn{
  background:linear-gradient(145deg,rgba(255,255,255,0.2),rgba(255,255,255,0.1));
  border:1.5px solid rgba(255,255,255,0.35);border-radius:16px;
  padding:16px 20px;cursor:pointer;text-align:left;
  color:#fff;font-family:'Nunito',sans-serif;font-size:.92rem;font-weight:600;
  transition:all .22s;position:relative;
  box-shadow:0 2px 12px rgba(0,20,80,0.15);line-height:1.45;
  backdrop-filter:blur(6px);
}
.opt-btn::after{content:attr(data-l);position:absolute;top:50%;right:14px;transform:translateY(-50%);
  font-size:.68rem;font-weight:800;color:rgba(255,255,255,0.3);font-family:'Fredoka One',sans-serif;}
.opt-btn:hover:not(:disabled){background:rgba(255,255,255,0.3);border-color:rgba(255,255,255,0.7);
  transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,20,80,0.25);}
.opt-btn.correct{background:rgba(46,213,115,0.25);border-color:var(--green);color:var(--green);}
.opt-btn.wrong{background:rgba(255,82,82,0.18);border-color:var(--red);color:#ff8a8a;}
.opt-btn:disabled{cursor:default;transform:none;}
.fb-box{padding:16px 20px;border-radius:16px;margin-top:16px;font-size:.9rem;line-height:1.6;display:none;}
.fb-box.show{display:block;animation:fadeUp .3s ease;}
.fb-ok{background:rgba(46,213,115,0.15);border:1.5px solid rgba(46,213,115,0.4);color:#6effa0;}
.fb-bad{background:rgba(255,82,82,0.12);border:1.5px solid rgba(255,82,82,0.35);color:#ff9a9a;}
.next-btn{display:none;width:100%;margin-top:16px;padding:15px;
  background:linear-gradient(135deg,var(--orange),var(--orange2));
  border:none;border-radius:16px;cursor:pointer;
  color:#fff;font-family:'Fredoka One',sans-serif;font-size:1.1rem;
  letter-spacing:.04em;transition:all .22s;
  box-shadow:0 6px 24px var(--orange-glow);}
.next-btn.show{display:block;animation:fadeUp .3s ease;}
.next-btn:hover{transform:translateY(-2px);box-shadow:0 10px 32px var(--orange-glow);}

/* ═══════════════════ BALANCER ═══════════════════ */
.bal-wrap{padding:32px 40px;}
.eq-display{display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  justify-content:center;margin:30px 0 24px;font-size:1.3rem;}
.eq-mol{color:var(--pale);font-family:'Fredoka One',sans-serif;}
.eq-plus{color:rgba(255,255,255,0.45);font-size:1.5rem;}
.eq-arrow{color:var(--teal);font-size:1.6rem;}
.coeff{width:50px;height:50px;text-align:center;
  background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.4);
  border-radius:12px;color:var(--gold);font-size:1.25rem;font-family:'Fredoka One',sans-serif;
  transition:border-color .2s;backdrop-filter:blur(6px);}
.coeff:focus{outline:none;border-color:var(--teal);box-shadow:0 0 0 3px rgba(30,207,176,0.25);}
.coeff.cok{border-color:var(--green);color:var(--green);}
.coeff.cbad{border-color:var(--red);color:#ff8a8a;}
.bal-hint{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.22);
  border-radius:14px;padding:12px 18px;margin:10px 0;
  font-size:.82rem;color:rgba(255,255,255,0.8);line-height:1.6;text-align:center;}
.check-btn{display:block;margin:0 auto;padding:13px 40px;
  background:linear-gradient(135deg,var(--teal),#0a9a84);
  border:none;border-radius:30px;cursor:pointer;
  color:#fff;font-family:'Fredoka One',sans-serif;font-size:1rem;
  letter-spacing:.04em;transition:all .22s;
  box-shadow:0 4px 20px rgba(30,207,176,0.4);}
.check-btn:hover{transform:scale(1.06);box-shadow:0 6px 28px rgba(30,207,176,0.55);}

/* ═══════════════════ FLASHCARD ═══════════════════ */
.fc-wrap{padding:32px 40px;}
.fc-scene{perspective:1100px;margin:24px auto;width:100%;max-width:560px;height:240px;cursor:pointer;}
.fc-inner{position:relative;width:100%;height:100%;
  transform-style:preserve-3d;transition:transform .65s cubic-bezier(.4,0,.2,1);}
.fc-inner.flip{transform:rotateY(180deg);}
.fc-face{position:absolute;inset:0;backface-visibility:hidden;
  border-radius:22px;display:flex;align-items:center;justify-content:center;
  padding:32px;text-align:center;}
.fc-front{background:linear-gradient(145deg,rgba(10,55,160,0.7),rgba(10,80,180,0.5));
  border:1.5px solid rgba(255,255,255,0.35);
  box-shadow:0 10px 40px rgba(0,20,100,0.4),inset 0 1px 0 rgba(255,255,255,0.15);}
.fc-back{background:linear-gradient(145deg,rgba(0,120,90,0.55),rgba(0,90,80,0.5));
  border:1.5px solid rgba(30,207,176,0.4);transform:rotateY(180deg);
  box-shadow:0 10px 40px rgba(0,80,60,0.3);}
.fcq{font-family:'Fredoka One',sans-serif;font-size:1.15rem;color:#fff;line-height:1.5;}
.fca{font-size:.92rem;color:#a0ffd8;line-height:1.65;}
.fctap{font-size:.72rem;color:rgba(255,255,255,0.45);margin-top:10px;letter-spacing:.1em;}
.fc-cnt{text-align:center;font-size:.78rem;color:rgba(255,255,255,0.5);margin-top:8px;font-weight:700;}
.fc-ctrls{display:flex;gap:14px;justify-content:center;margin-top:18px;}
.fc-btn{padding:10px 30px;border-radius:30px;cursor:pointer;
  font-family:'Nunito',sans-serif;font-size:.85rem;font-weight:700;transition:all .2s;border:2px solid;}
.fc-prev{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.35);color:#fff;}
.fc-prev:hover{background:rgba(255,255,255,0.22);}
.fc-next{background:linear-gradient(135deg,var(--orange),var(--orange2));border-color:transparent;color:#fff;}
.fc-next:hover{box-shadow:0 4px 18px var(--orange-glow);}

/* ═══════════════════ LEADERBOARD ═══════════════════ */
.lb-wrap{padding:32px 40px;}
.lb-row{display:flex;align-items:center;gap:14px;padding:14px 20px;
  border-radius:16px;margin-bottom:10px;
  background:rgba(255,255,255,0.12);border:1.5px solid rgba(255,255,255,0.22);
  backdrop-filter:blur(8px);transition:background .2s;
  box-shadow:0 2px 12px rgba(0,20,80,0.15);}
